# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# XEN Terminal — Environment Template
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Copy this to .env and fill in real values.
# NEVER commit the real .env file — it contains private keys.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ─── Owner Wallet ──────────────────────────────
# This wallet deploys the contract and receives all claimed XEN.
# Use a dedicated wallet — do NOT use your daily-driver wallet.
PRIVATE_KEY=0xYOUR_OWNER_PRIVATE_KEY_HERE
OWNER_ADDRESS=0xYOUR_OWNER_ADDRESS_HERE

# ─── Relayer Wallet ────────────────────────────
# Separate wallet that runs the automation bot.
# Only needs enough PLS for gas (~1000 PLS recommended).
# Has LIMITED permissions — cannot drain funds.
RELAYER_PRIVATE_KEY=0xYOUR_RELAYER_PRIVATE_KEY_HERE
RELAYER_ADDRESS=0xYOUR_RELAYER_ADDRESS_HERE

# ─── Contract Addresses ────────────────────────
# Filled in after deployment
MANAGER_ADDRESS=0xYOUR_DEPLOYED_MANAGER_ADDRESS

# ─── Configuration ─────────────────────────────
# Number of proxy wallets to deploy in initial setup
WALLET_COUNT=50

# Default mint term (days). Max ~517, grows over time.
MINT_TERM_DAYS=100

# Relayer check interval (milliseconds)
CHECK_INTERVAL_MS=600000

# ─── ERC-8004 Agent Identity (optional) ────────
# Deployed by scripts/deploy-erc8004.js
IDENTITY_REGISTRY=0xYOUR_IDENTITY_REGISTRY_ADDRESS
REPUTATION_REGISTRY=0xYOUR_REPUTATION_REGISTRY_ADDRESS
VALIDATION_REGISTRY=0xYOUR_VALIDATION_REGISTRY_ADDRESS
AGENT_ID=1

# Where your agent-card.json is hosted
# Examples:
#   https://raw.githubusercontent.com/Lokoweb3/xen-terminal/main/agent-card.json
#   ipfs://YOUR_CID_HERE
AGENT_URI=https://raw.githubusercontent.com/Lokoweb3/xen-terminal/main/agent-card.json
